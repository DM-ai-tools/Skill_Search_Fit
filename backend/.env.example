# PostgreSQL connection (asyncpg / psycopg)
# Railway Postgres provides DATABASE_URL (often postgres:// — normalized automatically)
DATABASE_URL=postgresql://skillsearchfit:<your-db-password>@localhost:5432/skillsearchfit

SESSION_SECRET=change-me-to-a-random-32-byte-string
SESSION_MAX_AGE=604800
CSRF_SECRET=change-me-to-another-random-string

# Comma-separated production frontend origin(s), e.g. https://your-app.up.railway.app
CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=development

ADMIN_EMAIL=admin@skillsearchfit.local
ADMIN_PASSWORD=Admin123!

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=16384
CHANGE_SUGGESTIONS_EXTRACTION_MAX_TOKENS=16384

OPENROUTER_API_KEY=
OPENROUTER_MODEL=perplexity/sonar-pro
OPENROUTER_FALLBACK_MODEL=perplexity/sonar
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=https://your-site.com
OPENROUTER_X_TITLE=Your App Name
WEBSITE_SCAN_TIMEOUT_SECONDS=90
WEBSITE_ANALYSIS_CACHE_DAYS=7

# WordPress (REST API — requires Application Password)
WP_SITE_URL=https://your-wordpress-site.com
WP_USERNAME=your-wp-username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Webflow (v2 API)
WEBFLOW_API_TOKEN=<your-webflow-api-token>
WEBFLOW_SITE_ID=<your-webflow-site-id>

# Wix (Headless REST API)
WIX_API_KEY=<your-wix-api-key>
WIX_SITE_ID=<your-wix-site-id>
