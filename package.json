{
  "name": "skillsearchfit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "setup:api": "cd backend && python -m venv .venv && .venv\\Scripts\\pip install -r requirements.txt",
    "dev:kill": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/kill-dev-ports.ps1",
    "dev:verify": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-dev-ports.ps1",
    "dev": "npm run dev:kill && concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "powershell -NoProfile -ExecutionPolicy Bypass -File backend/scripts/start-api.ps1",
    "dev:web": "npm run dev --prefix frontend -- --port 3000",
    "build": "npm run build --prefix frontend",
    "build:web": "npm run build --prefix frontend",
    "start:web": "npm run start --prefix frontend",
    "migrate": "cd backend && python scripts/migrate.py",
    "docker:build:api": "docker build -t skillsearchfit-api ./backend",
    "docker:build:web": "docker build -t skillsearchfit-web ./frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
