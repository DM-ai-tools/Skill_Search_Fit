# Railway environment variables — copy to each service in the Railway dashboard.
# Do not commit real secrets. Use Railway variable references where noted.

# ─── API service (root directory: backend) ───────────────────────────────────

DATABASE_URL=${{Postgres.DATABASE_URL}}
ENVIRONMENT=production
SESSION_SECRET=<generate-random-32+-chars>
CSRF_SECRET=<generate-random-32+-chars>
CORS_ORIGINS=https://<your-frontend>.up.railway.app

ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=<strong-password>

ANTHROPIC_API_KEY=<key>
OPENROUTER_API_KEY=<key>
# Do not set ANTHROPIC_MAX_TOKENS below 8192; extraction uses at least 16384 output tokens.
ANTHROPIC_MAX_TOKENS=16384
CHANGE_SUGGESTIONS_EXTRACTION_MAX_TOKENS=16384

# ─── Web service (root directory: frontend) ──────────────────────────────────

API_PROXY_TARGET=https://<your-backend>.up.railway.app
NEXT_PUBLIC_API_URL=https://<your-frontend>.up.railway.app/api/v1
NEXT_PUBLIC_APP_NAME=SkillSearchFit
API_PROXY_TIMEOUT_MS=600000

# Example with your domains:
# API_PROXY_TARGET=https://skillsearchfitbackend-production.up.railway.app
# NEXT_PUBLIC_API_URL=https://skillsearchfitfront-production.up.railway.app/api/v1
# CORS_ORIGINS=https://skillsearchfitfront-production.up.railway.app
